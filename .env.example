# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=admin_dashboard
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=admin_dashboard

# ── Ory Kratos Secrets (REQUIRED — generate strong random values) ──
# Generate with:
#   openssl rand -base64 32   (for cookie secret)
#   openssl rand -base64 32   (for cipher secret, must be 16/24/32 bytes)
KRATOS_SECRETS_COOKIE=ahV0eeph7pahp8ahgh6eegu7BuChaa9o
KRATOS_SECRETS_CIPHER=aiD4zooh3phoh9maTh7poh0aiw7waeJe

# ── Ory Kratos OIDC (optional — uncomment and fill for SSO) ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── SMTP (development: MailHog, production: SendGrid / SES) ──
# For production, set a real SMTP URI here:
# COURIER_SMTP_CONNECTION_URI=smtps://user:pass@smtp.sendgrid.net:465/?skip_ssl_verify=false
# Default below works with the dev MailHog container:
COURIER_SMTP_CONNECTION_URI=smtps://mailhog:1025/?skip_ssl_verify=true

# ── PostgREST JWT Secret (REQUIRED) ───────────────────────────
# Must match the JWT signing key used by Ory Kratos.
# Generate with: openssl rand -base64 32
PGRST_JWT_SECRET=super-secret-jwt-key-change-in-prod

# ── Frontend ───────────────────────────────────────────────────
# Public URL of the frontend (for Kratos redirects)
PUBLIC_FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8080/api

# ── OAuth / SSO Redirect URLs (set these to your public domain in prod) ──
# KRATOS_PUBLIC_URL=http://localhost:4433
# OAUTH_CALLBACK_URL=http://localhost:5173/auth/callback
