{
  "$id": "https://admin-dashboard.local/schemas/user.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "E-Mail",
          "description": "The primary email address of the user.",
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              },
              "code": {
                "identifier": true
              }
            },
            "verification": {
              "via": "email"
            },
            "recovery": {
              "via": "email"
            }
          }
        },
        "name": {
          "type": "object",
          "title": "Name",
          "description": "The user's full name split into first and last.",
          "properties": {
            "first": {
              "type": "string",
              "title": "First Name",
              "description": "The user's given name.",
              "minLength": 1,
              "maxLength": 128
            },
            "last": {
              "type": "string",
              "title": "Last Name",
              "description": "The user's family name.",
              "minLength": 1,
              "maxLength": 128
            }
          },
          "required": ["first", "last"]
        },
        "avatar_url": {
          "type": "string",
          "format": "uri",
          "title": "Avatar URL",
          "description": "URL to the user's profile picture or avatar.",
          "maxLength": 2048
        },
        "role": {
          "type": "string",
          "title": "Role",
          "description": "The authorization role assigned to the user.",
          "enum": ["admin", "user", "viewer"],
          "default": "user"
        },
        "company": {
          "type": "string",
          "title": "Company / Organization",
          "description": "The company or organization the user belongs to.",
          "maxLength": 256
        }
      },
      "required": ["email", "name"],
      "additionalProperties": false
    }
  },
  "required": ["traits"],
  "additionalProperties": false
}
